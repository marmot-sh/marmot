{
  "name": "@marmot-sh/core",
  "version": "0.7.1",
  "description": "Shared types, errors, retry, status, output formatters for marmot.",
  "type": "module",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./lib/*": "./src/lib/*.ts",
    "./output/*": "./src/output/*.ts",
    "./cache/*": "./src/cache/*.ts",
    "./types": "./src/types.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:all": "vitest run",
    "clean": "rm -rf dist",
    "lint": "eslint src",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "check": "pnpm lint && pnpm check-types && echo \"✅ All checks passed\" || { echo \"❌ Checks failed\"; exit 1; }"
  },
  "dependencies": {
    "ai": "^6.0.168",
    "ansis": "^4.2.0",
    "sucrase": "^3.35.1",
    "typescript": "^6.0.3",
    "yocto-spinner": "^1.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@marmot-sh/tsconfig": "workspace:*",
    "@types/node": "^25.6.0",
    "vitest": "^4.1.5"
  }
}

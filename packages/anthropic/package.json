{
  "name": "@marmot-sh/anthropic",
  "version": "0.3.1",
  "description": "@marmot-sh adapter for Anthropic Claude — text/image/speech/transcribe (where supported).",
  "type": "module",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:all": "vitest run",
    "clean": "rm -rf dist",
    "lint": "eslint src",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "check": "pnpm lint && pnpm check-types && echo \"✅ All checks passed\" || { echo \"❌ Checks failed\"; exit 1; }"
  },
  "dependencies": {
    "@marmot-sh/core": "workspace:*",
    "ai": "^6.0.168",
    "zod": "^4.3.6",
    "@ai-sdk/anthropic": "^3.0.71"
  },
  "devDependencies": {
    "@marmot-sh/tsconfig": "workspace:*",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}

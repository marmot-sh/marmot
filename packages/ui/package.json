{
  "name": "@marmot-sh/ui",
  "version": "0.11.4",
  "description": "Marmot React component library (shadcn/ui + Base UI primitives).",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./shadcn/*": "./src/components/ui/*.tsx",
    "./lib/*": "./src/lib/*.ts",
    "./styles.css": "./src/styles.css"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "echo \"ui: no tests\" && exit 0",
    "test:all": "echo \"ui: no tests\" && exit 0",
    "lint": "eslint src",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "check": "pnpm lint && pnpm check-types && echo \"✅ All checks passed\" || { echo \"❌ Checks failed\"; exit 1; }"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.511.0",
    "next-themes": "^0.4.6",
    "react-day-picker": "^9.14.0",
    "react-resizable-panels": "^4.10.0",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@marmot-sh/tsconfig": "workspace:*",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.9.2"
  }
}

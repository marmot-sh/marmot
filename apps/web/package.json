{
  "name": "@marmot-sh/web",
  "version": "0.1.0",
  "description": "marmot.sh landing page and reference docs.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "portless marmot vite dev",
    "build": "vite build",
    "preview": "vite preview --port 3001",
    "typecheck": "tsc --noEmit",
    "test": "echo \"web: no tests\" && exit 0",
    "test:all": "echo \"web: no tests\" && exit 0",
    "lint": "eslint src",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "check": "pnpm lint && pnpm check-types && echo \"✅ All checks passed\" || { echo \"❌ Checks failed\"; exit 1; }"
  },
  "homepage": "https://marmot.sh",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marmot-sh/marmot.git",
    "directory": "apps/web"
  },
  "bugs": {
    "url": "https://github.com/marmot-sh/marmot/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@fontsource-variable/archivo": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@marmot-sh/ui": "workspace:*",
    "@tailwindcss/vite": "^4.0.6",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-start": "^1.132.0",
    "@tanstack/router-plugin": "^1.132.0",
    "@vercel/og": "^0.6.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fumadocs-core": "^16.7.16",
    "fumadocs-mdx": "^14.3.0",
    "fumadocs-ui": "^16.7.16",
    "lucide-react": "^0.511.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "shadcn": "^4.6.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4"
  },
  "devDependencies": {
    "@types/mdx": "^2.0.13",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
